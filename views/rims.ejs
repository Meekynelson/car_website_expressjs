<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rims Collection</title>
    <!-- Tailwind CSS v4 Engine -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- External Custom Stylesheet -->
    <link rel="stylesheet" href="./css/rims.css">
</head>
<body class="bg-[#050505] text-white antialiased selection:bg-neutral-800 selection:text-white">

    <!-- 1. FIXED GLASSMORPHIC NAVBAR -->
    <nav class="fixed top-0 left-0 w-full z-50 flex items-center justify-between px-6 md:px-12 py-5 border-b border-neutral-900/40 bg-black/60 backdrop-blur-md">
        
        <!-- Hamburger Menu -->
        <!-- <button class="md:hidden flex flex-col justify-between h-3.5 w-5 text-white focus:outline-none">
            <span class="w-full h-[1.5px] bg-white"></span>
            <span class="w-full h-[1.5px] bg-white"></span>
            <span class="w-3/4 h-[1.5px] bg-white"></span>
        </button> -->

        <div class=" md:flex items-center space-x-8 text-[13px] font-medium tracking-[0.2em] uppercase text-neutral-400">
            <a href="/models" class="hover:text-white transition-colors">Models</a>
            <a href="/rims" class="hover:text-white transition-colors">Rims</a>
        </div>

        <!-- Logo -->
        <div id="logo" class="absolute left-1/2 -translate-x-1/2 text-sm md:text-2xl tracking-[0.35em] uppercase font-bold select-none whitespace-nowrap">
            <h1 class="font-luxury-serif text-white tracking-[0.01em]"><a href="/">MEEKYNELSON</a></h1>
        </div>

        <!-- Contact Us -->
        <div class="flex items-center text-[10px] md:text-[13px] font-medium tracking-[0.1em] uppercase text-neutral-400">
            <a href="/contact" class="transition-colors border border-neutral-800 px-1 py-1.5 md:px-2 md:py-2 hover:bg-white hover:text-black transition-all whitespace-nowrap">Contact Us</a>
        </div>
    </nav>

    <!-- 2. HEADER TITLE -->
    <header class="pt-40 pb-12 px-6 md:px-12 max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-neutral-900 pb-8">
            <div>
                <p class="text-[10px] tracking-[0.3em] text-neutral-500 uppercase font-semibold mb-2">Unsprung Mass Refinement</p>
                <h2 class="font-luxury-serif text-3xl md:text-5xl uppercase tracking-widest font-light">Forged Wheel Programs</h2>
            </div>
            <div class="text-xs text-neutral-500 tracking-widest uppercase font-light">
                [ Fully Integrated Spinning Caps ]
            </div>
        </div>
    </header>

    <!-- 3. RIMS CATALOG DISPLAY GRID -->
    <main class="px-6 md:px-12 max-w-7xl mx-auto pb-32">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            
            <!-- Wheel 1: MANSORY V.6 -->
            <div id="wheel" class="rim-card group flex flex-col justify-between p-8 h-[500px]">
                <div id="wheel-1" class="flex justify-between items-start">
                    <span class="dim-badge text-[12px] tracking-[0.25em] uppercase px-3 py-1.5 text-neutral-300 font-medium">Ultra Light-Alloy</span>
                    <span class="text-[14px] text-neutral-200 tracking-wider uppercase font-mono">TYPE V.6</span>
                </div>
                
                <!-- Central Wheel Visual Core -->
                <div class="w-full h-full mx-auto relative flex items-center justify-center my-4">
                    <img src="https://www.elitecustomrims.com/cdn/shop/files/kmvccqfoydbbqsx5bxjhamxr_1024x1024.png?v=1773777914" alt="Mansory V.6 Wheel" class="w-full h-full object-cover rounded-full rim-image">
                </div>
                
                <!-- <div class="space-y-4">
                    <div class="border-b border-neutral-900/60 pb-3">
                        <h3 class="font-luxury-serif text-xl uppercase tracking-wider text-white rim-link-effect inline-block">Mansory V.6 Variant</h3>
                        <p class="text-xs text-neutral-400 font-light mt-1">Multi-spoke orientation constructed for Rolls-Royce Ghost platforms and modern Bentley architectures.</p>
                    </div> -->
                    <!-- Architecture Blueprint Details -->
                    <!-- <div class="flex justify-between text-[10px] tracking-widest uppercase text-neutral-500">
                        <div><p class="font-medium text-neutral-600">Available Diameters</p><p class="text-white font-medium mt-0.5">22" / 23" / 24"</p></div>
                        <div class="text-right"><p class="font-medium text-neutral-600">Finishing Spec</p><p class="text-white font-medium mt-0.5">Gloss Diamond Black</p></div>
                    </div> -->
                <!-- </div> -->
            </div>

            <!-- Wheel 2: MANSORY Y.8 -->
            <div class="rim-card group flex flex-col justify-between p-8 h-[500px]">
                <div class="flex justify-between items-start">
                    <span class="dim-badge text-[12px] tracking-[0.25em] uppercase px-3 py-1.5 text-neutral-300 font-medium">Monoblock Forged</span>
                    <span class="text-[14px] text-neutral-200 tracking-wider uppercase font-mono">TYPE Y.8</span>
                </div>
                
                <div class="w-full h-full mx-auto relative flex items-center justify-center my-4">
                    <img src="https://elitecustoms.ae/cdn/shop/files/Screenshot_6_700x.png?v=1746817447" alt="Mansory Y.8 Wheel" class="w-full h-full object-cover rounded-full rim-image">
                </div>
                
            </div>

            <!-- Wheel 3: MANSORY FS.23 -->
            <div class="rim-card group flex flex-col justify-between p-8 h-[500px]">
                <div class="flex justify-between items-start">
                    <span class="dim-badge text-[12px] tracking-[0.25em] uppercase px-3 py-1.5 text-neutral-300 font-medium">Floating Cap Tech</span>
                    <span class="text-[14px] text-neutral-200 tracking-wider uppercase font-mono">TYPE FS.23</span>
                </div>
                
                <div class="w-full h-full mx-auto relative flex items-center justify-center my-4">
                    <img src="https://www.elitecustomrims.com/cdn/shop/files/1izdz1eyiyq1oaryzey2tbdu_1024x1024.png?v=1773777920" alt="Mansory FS.23 Wheel" class="w-full h-full object-cover rounded-full rim-image">
                </div>
                
            </div>

        </div>
    </main>

    <!-- 4. LUXURY BRAND FOOTER -->
    <footer class="bg-black text-neutral-600 text-xs py-12 px-6 md:px-12 border-t border-neutral-900/50">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
            <p class="tracking-widest font-light text-[11px] uppercase">&copy; 2026 MEEKYNELSON Design. All rights reserved.</p>
            <div class="flex flex-wrap justify-center space-x-6 md:space-x-8 tracking-widest uppercase text-[10px] font-medium">
                <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
                <a href="#" class="hover:text-white transition-colors">Legal Notice</a>
                <a href="#" class="hover:text-white transition-colors">Cookie Settings</a>
            </div>
        </div>
    </footer>

