<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us</title>
    <!-- Tailwind CSS v4 Engine -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- External Custom Stylesheet -->
    <link rel="stylesheet" href="./css/contact.css">
</head>
<body class="bg-[#050505] text-white antialiased selection:bg-neutral-800 selection:text-white">

    <!-- 1. FIXED GLASSMORPHIC NAVBAR -->
    <nav class="fixed top-0 left-0 w-full z-50 flex items-center justify-between px-6 md:px-12 py-5 border-b border-neutral-900/40 bg-black/60 backdrop-blur-md">

        <!-- Mobile Menu Toggle (Only visible on small screens) -->
        <button id="menu-toggle" class="md:hidden flex flex-col justify-between w-6 h-4 z-50 cursor-pointer" aria-label="Toggle Menu">
            <span class="w-full h-[1px] bg-white transition-all duration-300 origin-left" id="bar1"></span>
            <span class="w-full h-[1px] bg-white transition-all duration-300" id="bar2"></span>
            <span class="w-full h-[1px] bg-white transition-all duration-300 origin-left" id="bar3"></span>
        </button>

        <!-- Desktop Navigation Links (Hidden on mobile) -->
        <div class="hidden md:flex items-center space-x-8 text-[13px] font-medium tracking-[0.2em] uppercase text-neutral-400">
            <a href="/models" class="hover:text-white transition-colors">Models</a>
            <a href="/rims" class="hover:text-white transition-colors">Rims</a>
        </div>

        <!-- Centered Logo (Responsive translation and scaling) -->
        <div id="logo" class="absolute left-1/2 -translate-x-1/2 text-sm md:text-2xl tracking-[0.35em] uppercase font-bold select-none whitespace-nowrap">
            <h1 class="font-luxury-serif text-white tracking-[0.01em]"><a href="/">MEEKYNELSON</a></h1>
        </div>

        <!-- Contact Us CTA (Compact padding on small screens) -->
        <div class="flex items-center text-[10px] md:text-[13px] font-medium tracking-[0.15em] uppercase text-neutral-200">
            <a href="/contact" class="transition-colors border border-neutral-800 px-3 py-1.5 md:px-5 md:py-2 hover:bg-white hover:text-black transition-all whitespace-nowrap">Contact</a>
        </div>
    </nav>

    <!-- MOBILE FULLSCREEN DRAWER (Toggled via JS below) -->
    <div id="mobile-menu" class="fixed inset-0 bg-[#050505] z-40 flex flex-col justify-center items-center space-y-8 text-lg tracking-[0.25em] uppercase font-medium transition-all duration-500 transform -translate-y-full opacity-0">
        <a href="/" class="hover:text-white text-neutral-400 transition-colors">Home</a>
        <a href="/models" class="hover:text-white text-neutral-400 transition-colors">Models</a>
        <a href="/rims" class="hover:text-white text-neutral-400 transition-colors">Rims</a>
        <a href="/contact" class="text-white transition-colors">Contact Us</a>
    </div>

    <!-- MAIN SPLIT CONTACT CONTENT GRID -->
    <main class="pt-32 lg:pt-44 pb-20 lg:pb-32 px-6 md:px-12 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
        
        <!-- LEFT COLUMN: PREMIUM COMMUNICATIONS FORM -->
        <section class="lg:col-span-7 space-y-10 sm:space-y-12">
            <div class="space-y-3">
                <p class="text-xs sm:text-[13px] tracking-[0.3em] text-neutral-500 uppercase font-semibold">Inquiries & Commissions</p>
                <h2 class="font-luxury-serif text-3xl sm:text-4xl md:text-5xl uppercase tracking-widest font-light leading-tight">Connect With Us</h2>
                <p class="text-sm text-neutral-400 font-light max-w-md leading-relaxed">Reach out to arrange a bespoke vehicle consultation or request physical catalog assets.</p>
            </div>

            <!-- Form Fields Section -->
            <form action="/contacts" method="POST" class="space-y-10 pt-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
                    <!-- Full Name -->
                    <div class="flex flex-col-reverse">
                        <input type="text" id="name" name="name" required class="premium-input" placeholder=" ">
                        <label for="name" class="premium-label">Full Name</label>
                    </div>
                    <!-- Email Address -->
                    <div class="flex flex-col-reverse">
                        <input type="email" id="email" name="email" required class="premium-input" placeholder=" ">
                        <label for="email" class="premium-label">Email Address</label>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
                    <!-- Phone Number -->
                    <div class="flex flex-col-reverse">
                        <input type="tel" id="phone" name="phone" class="premium-input" placeholder=" ">
                        <label for="phone" class="premium-label">Phone</label>
                    </div>
                    <!-- Subject Matter -->
                    <div class="flex flex-col-reverse">
                        <input type="text" id="subject" name="subject" class="premium-input" placeholder=" ">
                        <label for="subject" class="premium-label">Car of Interest</label>
                    </div>
                </div>

                <!-- Detailed Message Box -->
                <div class="flex flex-col-reverse">
                    <textarea id="message" name="message" rows="4" required class="premium-input resize-none" placeholder=" "></textarea>
                    <label for="message" class="premium-label">Your Message / Bespoke Requirements</label>
                </div>

                <!-- Submission Button -->
                <div class="pt-4">
                    <button type="submit" class="w-full sm:w-auto bg-white border border-white text-black px-12 py-4 text-[11px] tracking-[0.25em] uppercase font-semibold hover:bg-transparent hover:text-white transition-all duration-300 cursor-pointer shadow-xl">
                        Submit Request
                    </button>
                </div>
            </form>
        </section>

        <!-- RIGHT COLUMN: COORDINATES & HEADQUARTERS -->
        <aside class="lg:col-span-5 space-y-10">
            <!-- Brand Showroom Metadata -->
            <div class="showroom-card p-8 sm:p-10 space-y-8">
                <h3 class="font-luxury-serif text-lg uppercase tracking-wider border-b border-neutral-900 pb-4">Global Headquarters</h3>
                
                <!-- Coordinate Block 1 -->
                <div class="space-y-1.5 text-xs font-light text-neutral-400">
                    <p class="text-[10px] tracking-widest uppercase text-neutral-600 font-medium">Main Office Location</p>
                    <p class="text-white leading-relaxed tracking-wide">
                        KM 46, Lagos-Ibadan Expressway,<br>
                        Ogun State, Nigeria.
                    </p>
                </div>

                <!-- Coordinate Block 2 -->
                <div class="space-y-1.5 text-xs font-light text-neutral-400">
                    <p class="text-[10px] tracking-widest uppercase text-neutral-600 font-medium">Direct Comms</p>
                    <p class="tracking-wide leading-relaxed">
                        <span class="text-neutral-500">Phone:</span> <a href="tel:+23490123456" class="hover:text-white text-white transition-colors">+234 901 234 5678</a><br>
                        <span class="text-neutral-500">Inquiries:</span> <a href="mailto:meekynelson@gmail.com" class="hover:text-white text-white transition-colors">meekynelson@gmail.com</a>
                    </p>
                </div>

                <!-- Coordinate Block 3 -->
                <div class="space-y-1.5 text-xs font-light text-neutral-400">
                    <p class="text-[10px] tracking-widest uppercase text-neutral-600 font-medium">Consultation Hours</p>
                    <p class="text-white tracking-wide leading-relaxed">
                        Monday – Friday: 08:00 – 18:00 WAT<br>
                        <span class="text-neutral-600 block mt-1">Weekend Showroom by private reservation only.</span>
                    </p>
                </div>
            </div>

            <!-- Aesthetic Brand Image Accent Overlay -->
            <div class="h-64 sm:h-72 lg:h-84 w-full overflow-hidden relative border border-neutral-900/50">
                <div class="absolute inset-0 bg-neutral-950/2 mix-blend-multiply z-10"></div>
                <img src="https://www.hdcarwallpapers.com/download/rolls_royce_phantom_5k-3840x2160.jpg" alt="Consultation lounge asset" class="w-full h-full object-cover filter brightness-80 contrast-125 saturate-50">
            </div>
        </aside>
    </main>

    <!-- 3. LUXURY BRAND FOOTER -->
    <footer class="bg-black text-neutral-300 text-sm py-12 px-6 md:px-12 border-t border-neutral-900/10">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
            <p class="tracking-widest font-light text-[11px] uppercase">&copy; 2026 MEEKYNELSON Design. All rights reserved.</p>
            <div class="flex flex-wrap justify-center gap-6 md:gap-8 tracking-widest uppercase text-[10px] font-medium">
                <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
                <a href="#" class="hover:text-white transition-colors">Legal Notice</a>
                <a href="#" class="hover:text-white transition-colors">Cookie Settings</a>
            </div>
        </div>
    </footer>

    <!-- Interactive Navigation Menu Script -->
    <script>
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const bar1 = document.getElementById('bar1');
        const bar2 = document.getElementById('bar2');
        const bar3 = document.getElementById('bar3');

        menuToggle.addEventListener('click', () => {
            const isOpen = mobileMenu.classList.contains('translate-y-0');
            
            if (isOpen) {
                // Close Menu
                mobileMenu.classList.remove('translate-y-0', 'opacity-100');
                mobileMenu.classList.add('-translate-y-full', 'opacity-0');
                // Revert Hamburger Icon
                bar1.classList.remove('rotate-45', 'translate-y-[6px]');
                bar2.classList.remove('opacity-0');
                bar3.classList.remove('-rotate-45', '-translate-y-[6px]');
            } else {
                // Open Menu
                mobileMenu.classList.remove('-translate-y-full', 'opacity-0');
                mobileMenu.classList.add('translate-y-0', 'opacity-100');
                // Transform to 'X' Icon
                bar1.classList.add('rotate-45', 'translate-y-[6px]');
                bar2.classList.add('opacity-0');
                bar3.classList.add('-rotate-45', '-translate-y-[6px]');
            }
        });
    </script>
</body>
</html>