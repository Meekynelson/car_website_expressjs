<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Discover Cullinan II — Meekynelson</title>
    <!-- Tailwind CSS v4 Engine -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Custom Style System -->
    <link rel="stylesheet" href="./css/discover.css">
</head>
<body class="bg-[#050505] text-white antialiased selection:bg-neutral-800 selection:text-white">

    <!-- 1. NAVIGATION BAR -->
    <nav class="fixed top-0 left-0 w-full z-50 flex items-center justify-between px-6 md:px-12 py-5 border-b border-neutral-900/40 bg-black/60 backdrop-blur-md">
        <button id="menu-toggle" class="md:hidden flex flex-col justify-between w-6 h-4 z-50 cursor-pointer" aria-label="Toggle Menu">
            <span class="w-full h-[1px] bg-white transition-all duration-300 origin-left" id="bar1"></span>
            <span class="w-full h-[1px] bg-white transition-all duration-300" id="bar2"></span>
            <span class="w-full h-[1px] bg-white transition-all duration-300 origin-left" id="bar3"></span>
        </button>

        <div class="hidden md:flex items-center space-x-8 text-[13px] font-medium tracking-[0.2em] uppercase text-neutral-400">
            <a href="/models" class="hover:text-white transition-colors">Models</a>
            <a href="/rims" class="hover:text-white transition-colors">Rims</a>
        </div>

        <div id="logo" class="absolute left-1/2 -translate-x-1/2 text-sm sm:text-base md:text-2xl tracking-[0.35em] uppercase font-bold select-none whitespace-nowrap">
            <h1 class="font-luxury-serif text-white tracking-[0.01em]"><a href="/">MEEKYNELSON</a></h1>
        </div>

        <div class="flex items-center text-[10px] md:text-[13px] font-medium tracking-[0.15em] uppercase text-neutral-400">
            <a href="/contact" class="transition-colors border border-neutral-800 px-3 py-1.5 md:px-5 md:py-2 hover:bg-white hover:text-black transition-all whitespace-nowrap">Contact</a>
        </div>
    </nav>

    <!-- MOBILE FULLSCREEN DRAWER -->
    <div id="mobile-menu" class="fixed inset-0 bg-[#050505] z-40 flex flex-col justify-center items-center space-y-8 text-lg tracking-[0.25em] uppercase font-medium transition-all duration-500 transform -translate-y-full opacity-0">
        <a href="/models" class="text-neutral-400 hover:text-white transition-colors">Models</a>
        <a href="/rims" class="text-neutral-400 hover:text-white transition-colors">Rims</a>
        <a href="/contact" class="text-neutral-400 hover:text-white transition-colors">Contact Us</a>
    </div>

    <!-- 2. SPLIT HERO SECTION -->
    <section class="min-h-screen pt-28 flex flex-col justify-center relative px-6 md:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center py-12">
            
            <!-- Structural Details Text Block -->
            <div class="lg:col-span-5 space-y-6 lg:pr-6">
                <span class="text-[10px] tracking-[0.35em] uppercase text-neutral-500 font-semibold block">Series Launch // 2025</span>
                <h2 class="font-luxury-serif text-4xl sm:text-5xl lg:text-6xl uppercase tracking-wider font-light leading-none text-white">
                    Cullinan <br class="hidden lg:inline" />Edition II
                </h2>
                <div class="h-[1px] w-20 bg-neutral-800 my-4"></div>
                <p class="text-sm text-neutral-400 leading-relaxed font-light">
                    An evolution in imposing design. The Cullinan II refines the luxury SUV layout with vertically aligned daytime running lights, a subtle illuminated Pantheon grille, and integrated geometric styling.
                </p>
                <div class="flex gap-8 pt-4">
                    <div>
                        <span class="text-[10px] uppercase text-neutral-500 tracking-wider">Engine</span>
                        <p class="text-lg font-light tracking-wide mt-1">6.75L V12 Twin-Turbo</p>
                    </div>
                    <div>
                        <span class="text-[10px] uppercase text-neutral-500 tracking-wider">Output</span>
                        <p class="text-lg font-light tracking-wide mt-1">563 BHP</p>
                    </div>
                </div>
            </div>

            <!-- Big Scale Hero Visual -->
            <div class="lg:col-span-7 reveal-wrapper overflow-hidden rounded-[2px] border border-neutral-900 h-[300px] sm:h-[450px] lg:h-[550px] relative">
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent z-10 pointer-events-none"></div>
                <img src="https://www.hdcarwallpapers.com/download/urban_automotive_rolls_royce_cullinan_2025_8k-3840x2160.jpg" alt="Rolls-Royce Cullinan II Exterior Profile" class="w-full h-full object-cover reveal-image" />
            </div>

        </div>
    </section>

    <!-- 3. INTERIOR GALLERY -->
    <section class="bg-neutral-950/40 py-24 border-y border-neutral-900/40">
        <div class="max-w-7xl mx-auto px-6 md:px-12">
            <div class="mb-12 text-center lg:text-left">
                <p class="text-[10px] tracking-[0.3em] text-neutral-500 uppercase font-semibold mb-2">Interior Architectures</p>
                <h3 class="font-luxury-serif text-2xl md:text-4xl uppercase tracking-wider font-light">The Gallery Sanctuary</h3>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Driver Cockpit Profile -->
                <div class="space-y-4">
                    <div class="overflow-hidden rounded-[2px] border border-neutral-900/60 h-[250px] sm:h-[350px]">
                        <img src="https://encrypted-tbn0.gstatic.com/licensed-image?q=tbn:ANd9GcR2QHZ8a984lqDGDaqBu7ht5NkhiNHbCRfHbhcoBqcolV7mfzIEBX78u8wi3hMTCRgyTTwGPupC3tN-GuA" alt="Cullinan II Cockpit Console" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
                    </div>
                    <h4 class="font-luxury-serif text-lg tracking-wide">The Glass Dashboard Facade</h4>
                    <p class="text-xs text-neutral-400 leading-relaxed font-light">A unified glass panel spans the front cabin, embedding high-resolution digital instruments along with the Spirit of Ecstasy clock cabinet.</p>
                </div>

                <!-- Passenger Theatre Rear Cabin -->
                <div class="space-y-4">
                    <div class="overflow-hidden rounded-[2px] border border-neutral-900/60 h-[250px] sm:h-[350px]">
                        <img src="https://www.oraclefinance.co.uk/wp-content/uploads/2023/02/boutique-coolbox-ghost-rr2x-carousel--scaled.jpg" alt="Cullinan II Rear Seats" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
                    </div>
                    <h4 class="font-luxury-serif text-lg tracking-wide">Starlight Serenity Suite</h4>
                    <p class="text-xs text-neutral-400 leading-relaxed font-light">Equipped with the signature Starlight headliner, rear dining tables, integrated champagne cooler compartments, and plush lamb's wool floor mats.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- 4. SIGNATURE PERFORMANCE BANNER -->
    <section class="max-w-7xl mx-auto px-6 md:px-12 py-24">
        <div class="border border-neutral-900 p-8 md:p-16 flex flex-col lg:flex-row items-center justify-between gap-12 bg-gradient-to-br from-neutral-950 to-transparent">
            <div class="space-y-4 max-w-xl">
                <h3 class="font-luxury-serif text-2xl md:text-3xl uppercase tracking-wider font-light">Configure Your Model II</h3>
                <p class="text-xs text-neutral-400 leading-relaxed font-light">Our commissions programs let you configure custom forged wheel specs, interior bespoke veneers, and paint options.</p>
            </div>
            <a href="/contact" class="px-8 py-4 border border-white text-xs tracking-[0.2em] uppercase font-semibold hover:bg-white hover:text-black transition-all shrink-0">
                Inquire commission
            </a>
        </div>
    </section>

    <!-- 5. LUXURY BRAND FOOTER -->
    <footer class="bg-black text-neutral-300 text-sm py-12 px-6 md:px-12 border-t border-neutral-900/10">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
            <p class="tracking-widest font-light text-[11px] uppercase">&copy; 2026 MEEKYNELSON Design. All rights reserved.</p>
            <div class="flex flex-wrap justify-center gap-6 md:gap-8 tracking-widest uppercase text-[10px] font-medium">
                <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
                <a href="#" class="hover:text-white transition-colors">Legal Notice</a>
                <a href="#" class="hover:text-white transition-colors">Cookie Settings</a>
            </div>
        </div>
    </footer>

    <!-- Interactive Navigation Toggle Script -->
    <script>
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const bar1 = document.getElementById('bar1');
        const bar2 = document.getElementById('bar2');
        const bar3 = document.getElementById('bar3');

        menuToggle.addEventListener('click', () => {
            const isOpen = mobileMenu.classList.contains('translate-y-0');
            
            if (isOpen) {
                mobileMenu.classList.remove('translate-y-0', 'opacity-100');
                mobileMenu.classList.add('-translate-y-full', 'opacity-0');
                bar1.classList.remove('rotate-45', 'translate-y-[6px]');
                bar2.classList.remove('opacity-0');
                bar3.classList.remove('-rotate-45', '-translate-y-[6px]');
            } else {
                mobileMenu.classList.remove('-translate-y-full', 'opacity-0');
                mobileMenu.classList.add('translate-y-0', 'opacity-100');
                bar1.classList.add('rotate-45', 'translate-y-[6px]');
                bar2.classList.add('opacity-0');
                bar3.classList.add('-rotate-45', '-translate-y-[6px]');
            }
        });
    </script>
</body>
</html>