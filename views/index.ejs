<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="./css/main.css">
</head>
<body class="bg-black text-white antialiased selection:bg-neutral-800 selection:text-white overflow-x-hidden">

    <!-- NAVIGATION -->
    <nav class="fixed top-0 left-0 w-full z-50 flex items-center justify-between px-6 md:px-12 py-5 border-b border-neutral-900/40 bg-black/60 backdrop-blur-md">
        
        <!-- Mobile Menu Toggle (Only visible on mobile screens) -->
        <button id="menu-toggle" class="md:hidden flex flex-col justify-between w-6 h-4 z-50 cursor-pointer" aria-label="Toggle Menu">
            <span class="w-full h-[1px] bg-white transition-all duration-300 origin-left" id="bar1"></span>
            <span class="w-full h-[1px] bg-white transition-all duration-300" id="bar2"></span>
            <span class="w-full h-[1px] bg-white transition-all duration-300 origin-left" id="bar3"></span>
        </button>

        <!-- Desktop Navigation links (Hidden on mobile to prevent overlapping with central logo) -->
        <div class="hidden md:flex items-center space-x-8 text-[13px] font-medium tracking-[0.2em] uppercase text-neutral-400">
            <a href="/models" class="text-white transition-colors border-b border-white/40 pb-1">Models</a>
            <a href="/rims" class="hover:text-white transition-colors">Rims</a>
        </div>

        <!-- Centered Logo (Responsive scaling and positioning) -->
        <div id="logo" class="absolute left-1/2 -translate-x-1/2 text-sm sm:text-base md:text-2xl tracking-[0.35em] uppercase font-bold select-none whitespace-nowrap">
            <h1 class="font-luxury-serif text-white tracking-[0.01em]"><a href="/">MEEKYNELSON</a></h1>
        </div>

        <!-- Contact Us CTA -->
        <div class="flex items-center text-[10px] md:text-[13px] font-medium tracking-[0.15em] uppercase text-neutral-400">
            <a href="/contact" class="transition-colors border border-neutral-800 px-3 py-1.5 md:px-5 md:py-2 hover:bg-white hover:text-black transition-all whitespace-nowrap">Contact</a>
        </div>
    </nav>

    <!-- MOBILE FULLSCREEN DRAWER (Toggled via JavaScript below) -->
    <div id="mobile-menu" class="fixed inset-0 bg-[#050505] z-40 flex flex-col justify-center items-center space-y-8 text-lg tracking-[0.25em] uppercase font-medium transition-all duration-500 transform -translate-y-full opacity-0">
        <a href="/models" class="text-white transition-colors">Models</a>
        <a href="/rims" class="hover:text-white text-neutral-400 transition-colors">Rims</a>
        <a href="/contact" class="hover:text-white text-neutral-400 transition-colors">Contact Us</a>
    </div>

    <!-- Notification Toasts -->
    <% if(session?.status == 'success') { %>
        <h1 class="fixed top-24 left-1/2 -translate-x-1/2 bg-gray-600 text-white px-4 py-2 text-sm rounded shadow-lg z-50 whitespace-nowrap">
            <%= session.message %>
        </h1>
    <% } else if(session?.status == 'error') { %>
        <h1 class="fixed top-24 left-1/2 -translate-x-1/2 bg-red-900 text-white px-4 py-2 text-sm rounded shadow-lg z-50 whitespace-nowrap">
            <%= session.message %>
        </h1>
    <% } %>

    <!-- MAIN HERO CONTENT -->
    <main class="relative w-screen h-dvh bg-[#070707] flex flex-col justify-between overflow-hidden">
        <div class="spotlight"></div>
        
        <div class="relative w-full h-full flex items-center mx-auto">
    
            <!-- Background Image Engine (Restored original scale & center attributes) -->
            <div class="absolute inset-0 w-full h-full pointer-events-none">
                <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-black/20 lg:bg-gradient-to-r lg:from-black/90 lg:via-black/40 lg:to-transparent z-10"></div>
                
                <img src="https://www.hdcarwallpapers.com/download/brabus_700_2025-1920x1080.jpg" 
                     alt="Rolls Royce Cullinan II 2025 Edition" 
                     class="w-full h-full object-cover z-0 premium-car-img scale-105 object-center">
            </div>
        
            <!-- Responsive Content Box (Restored original padding, button nesting structure, and active scaling transitions) -->
            <div class="relative z-20 flex flex-col justify-center items-center lg:items-start text-center lg:text-left px-4 sm:px-6 lg:px-8 max-w-xl w-full mx-auto lg:mx-10 transition-all duration-500 py-16 sm:py-20 lg:py-0">
                <h1 class="font-luxury-serif text-2xl sm:text-3xl md:text-4xl font-light uppercase tracking-wide leading-[1.1] text-white drop-shadow-lg">
                    Rolls Royces cullinan II 2025 Edition
                </h1>
                <p class="mt-4 md:mt-6 text-sm sm:text-base font-light text-neutral-300 max-w-md leading-relaxed tracking-wide">
                    Bespoke carbon fiber anatomy and custom luxury refinements tailored for the ultimate Rolls-Royce electric coupe.
                </p>
                <div class="mt-8 w-full sm:w-auto">
                    <button class="w-full sm:w-auto inline-flex justify-center bg-[#1e2d3b]/40 border border-[#2d4358]/60 text-[#bfe3ff] px-8 sm:px-10 py-3.5 text-[11px] tracking-[0.25em] uppercase font-semibold hover:bg-[#25394d]/60 hover:text-white active:scale-95 transition-all duration-300 backdrop-blur-sm cursor-pointer shadow-2xl">
                        <a href="/discover">Discover Now</a>
                    </button>
                </div>
            </div>
        
        </div>
    </main>

    <!-- BRAND COLLECTIONS SECTION -->
    <section class="bg-[#0b0b0b] py-16 sm:py-20 lg:py-24 px-4 sm:px-6 md:px-12 border-t border-neutral-950">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16 space-y-3">
                <p class="text-[10px] tracking-[0.3em] text-neutral-500 uppercase font-semibold">Empowering Masterpieces</p>
                <h2 class="font-luxury-serif text-3xl md:text-4xl uppercase tracking-widest font-light">The Collections</h2>
                <div class="w-12 h-[1px] bg-neutral-700 mx-auto mt-4"></div>
            </div>

            <!-- Responsive Grid (Restored original h-[450px] layouts and group-hover scaling transitions) -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Card 1 -->
                <div class="relative group h-[450px] overflow-hidden bg-neutral-900 border border-neutral-900/40">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent z-10"></div>
                    <img src="https://images.unsplash.com/photo-1617814076367-b759c7d7e738?auto=format&fit=crop&w=600&q=80" alt="Supercars" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 brightness-75">
                    <div class="absolute bottom-8 left-8 z-20 space-y-2">
                        <h3 class="font-luxury-serif text-xl uppercase tracking-wider">Supercars</h3>
                        <p class="text-xs text-neutral-400 tracking-widest uppercase group-hover:text-white transition-colors">Explore Alterations &rarr;</p>
                    </div>
                </div>
                <!-- Card 2 -->
                <div class="relative group h-[450px] overflow-hidden bg-neutral-900 border border-neutral-900/40">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent z-10"></div>
                    <img src="https://images.unsplash.com/photo-1533473359331-0135ef1b58bf?auto=format&fit=crop&w=600&q=80" alt="Luxury SUVs" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 brightness-75">
                    <div class="absolute bottom-8 left-8 z-20 space-y-2">
                        <h3 class="font-luxury-serif text-xl uppercase tracking-wider">Luxury SUVs</h3>
                        <p class="text-xs text-neutral-400 tracking-widest uppercase group-hover:text-white transition-colors">Explore Alterations &rarr;</p>
                    </div>
                </div>
                <!-- Card 3 -->
                <div class="relative group h-[450px] overflow-hidden bg-neutral-900 border border-neutral-900/40">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent z-10"></div>
                    <img src="https://images.unsplash.com/photo-1605559424843-9e4c228bf1c2?auto=format&fit=crop&w=600&q=80" alt="Bespoke Rims" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 brightness-75">
                    <div class="absolute bottom-8 left-8 z-20 space-y-2">
                        <h3 class="font-luxury-serif text-xl uppercase tracking-wider">Bespoke Rims</h3>
                        <p class="text-xs text-neutral-400 tracking-widest uppercase group-hover:text-white transition-colors">View Details &rarr;</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-black text-neutral-300 text-sm py-12 px-6 md:px-12 border-t border-neutral-900/10">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
            <p class="tracking-widest font-light text-[11px] uppercase">&copy; 2026 MEEKYNELSON Design. All rights reserved.</p>
            <div class="flex flex-wrap justify-center gap-6 md:gap-8 tracking-widest uppercase text-[10px] font-medium">
                <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
                <a href="#" class="hover:text-white transition-colors">Legal Notice</a>
                <a href="#" class="hover:text-white transition-colors">Cookie Settings</a>
            </div>
        </div>
    </footer>

    <!-- INTERACTIVE MENU TOGGLE SCRIPT -->
    <script>
         const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const bar1 = document.getElementById('bar1');
        const bar2 = document.getElementById('bar2');
        const bar3 = document.getElementById('bar3');

        menuToggle.addEventListener('click', () => {
            const isOpen = mobileMenu.classList.contains('translate-y-0');
            
            if (isOpen) {
                // Close Menu
                mobileMenu.classList.remove('translate-y-0', 'opacity-100');
                mobileMenu.classList.add('-translate-y-full', 'opacity-0');
                // Revert Burger Icon to normal lines
                bar1.classList.remove('rotate-45', 'translate-y-[6px]');
                bar2.classList.remove('opacity-0');
                bar3.classList.remove('-rotate-45', '-translate-y-[6px]');
            } else {
                // Open Menu
                mobileMenu.classList.remove('-translate-y-full', 'opacity-0');
                mobileMenu.classList.add('translate-y-0', 'opacity-100');
                // Transform Hamburger Icon into 'X'
                bar1.classList.add('rotate-45', 'translate-y-[6px]');
                bar2.classList.add('opacity-0');
                bar3.classList.add('-rotate-45', '-translate-y-[6px]');
            }
        });
    </script>
</body>
</html>